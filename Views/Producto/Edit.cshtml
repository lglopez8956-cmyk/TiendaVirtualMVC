@model TiendaVirtualMVC.Models.Producto

<div class="container mt-4">
    <h2>Editar Producto</h2>

    <form asp-action="Edit" method="post">
        @* 1. ID OCULTO: Obligatorio para que EF sepa qué editar *@
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Precio</label>
            <input asp-for="Precio" class="form-control" />
            <span asp-validation-for="Precio" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Stock</label>
            <input asp-for="Stock" class="form-control" />
            <span asp-validation-for="Stock" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Categoría</label>
            @* 2. SELECT: asp-for="CategoriaId" vincula el ID directamente *@
            <select asp-for="CategoriaId" class="form-select"
                    asp-items="@(new SelectList(ViewBag.Categorias, "Id", "Nombre"))">
                <option value="">-- Seleccione una Categoría --</option>
            </select>
            <span asp-validation-for="CategoriaId" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Actualizar</button>
        <a asp-action="Index" class="btn btn-secondary">Regresar</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}