@model TiendaVirtualMVC.Models.Producto

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Editar Producto</h4>
                </div>
                <div class="card-body">
                    @* Se agrega enctype para permitir el envío de la nueva imagen *@
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">

                        @* ID OCULTO: Obligatorio para que EF sepa qué editar *@
                        <input type="hidden" asp-for="Id" />
                        @* Mantenemos la URL de la imagen actual si no se sube una nueva *@
                        <input type="hidden" asp-for="ImagenUrl" />

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Nombre" class="form-label font-weight-bold"></label>
                                    <input asp-for="Nombre" class="form-control" />
                                    <span asp-validation-for="Nombre" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Precio" class="form-label font-weight-bold"></label>
                                    <input asp-for="Precio" class="form-control" type="number" step="0.01" />
                                    <span asp-validation-for="Precio" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Stock" class="form-label font-weight-bold"></label>
                                    <input asp-for="Stock" class="form-control" type="number" />
                                    <span asp-validation-for="Stock" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label font-weight-bold">Categoría</label>
                                    <select asp-for="CategoriaId" class="form-select"
                                            asp-items="@(new SelectList(ViewBag.Categorias, "Id", "Nombre"))">
                                        <option value="">-- Seleccione una Categoría --</option>
                                    </select>
                                    <span asp-validation-for="CategoriaId" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6 border-start">
                                @* SECCIÓN DE IMAGEN SEGÚN image_3b4cab.jpg *@
                                <div class="mb-3 text-center">
                                    <label class="form-label font-weight-bold text-primary">Imagen actual</label><br />
                                    @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                                    {
                                        <img src="@Model.ImagenUrl" width="150" class="mb-2 img-thumbnail shadow-sm" />
                                    }
                                    else
                                    {
                                        <img src="/images/no-image.png" width="150" class="mb-2 img-thumbnail shadow-sm" />
                                    }
                                </div>

                                <div class="mb-3">
                                    <label class="form-label font-weight-bold">Nueva imagen (opcional)</label>
                                    <input type="file" name="imagen" class="form-control" accept="image/*" />
                                    <small class="text-muted">Deje en blanco para conservar la imagen actual.</small>
                                </div>
                            </div>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-warning px-4">
                                <i class="fas fa-sync-alt"></i> Actualizar Producto
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}