@model TiendaVirtualMVC.Models.Producto

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Editar Producto</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        @* Resumen de errores para depuración *@
                        <div asp-validation-summary="All" class="text-danger small mb-3"></div>
                        
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ImagenUrl" />

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Nombre" class="form-label font-weight-bold"></label>
                                    <input asp-for="Nombre" class="form-control" placeholder="Ej. Zapatos Gucci" />
                                    <span asp-validation-for="Nombre" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Precio" class="form-label font-weight-bold"></label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input asp-for="Precio" class="form-control" type="number" step="any" />
                                    </div>
                                    <span asp-validation-for="Precio" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Stock" class="form-label font-weight-bold"></label>
                                    <input asp-for="Stock" class="form-control" type="number" />
                                    <span asp-validation-for="Stock" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label font-weight-bold">Categoría</label>
                                    <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId">
                                        <option value="">-- Seleccione una Categoría --</option>
                                    </select>
                                    <span asp-validation-for="CategoriaId" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6 border-start">
                                <div class="mb-3 text-center">
                                    <p class="form-label font-weight-bold text-primary">Imagen actual</p>
                                    <img src="@(string.IsNullOrEmpty(Model.ImagenUrl) ? "/images/no-image.png" : Model.ImagenUrl)"
                                         width="150" class="img-thumbnail shadow-sm mb-2" alt="Producto" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label font-weight-bold">Nueva imagen (opcional)</label>
                                    <input type="file" name="imagen" class="form-control" accept="image/*" />
                                    <small class="text-muted d-block mt-1">Deje en blanco para conservar la actual.</small>
                                </div>
                            </div>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-warning px-4 fw-bold">
                                <i class="fas fa-sync-alt"></i> Actualizar Producto
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}