@model TiendaVirtualMVC.Models.Producto

<div class="container mt-4">
    <h2>Crear Producto</h2>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input asp-for="Nombre" class="form-control" placeholder="Ej: Zapatos Gucci" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Precio</label>
            <input asp-for="Precio" class="form-control" type="number" />
            <span asp-validation-for="Precio" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Stock</label>
            <input asp-for="Stock" class="form-control" type="number" />
            <span asp-validation-for="Stock" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Categoría</label>
            @* Usamos asp-for para que se guarde en el campo CategoriaId *@
            <select asp-for="CategoriaId" class="form-select"
                    asp-items="@(new SelectList(ViewBag.Categorias, "Id", "Nombre"))">
                <option value="">-- Seleccione una Categoría --</option>
            </select>
            <span asp-validation-for="CategoriaId" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Guardar</button>
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </form>
</div>