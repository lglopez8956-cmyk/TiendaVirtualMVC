@model IEnumerable<TiendaVirtualMVC.Models.Producto>
@using Microsoft.AspNetCore.Http

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Catálogo de Productos</h2>
        <div>
            <a class="btn btn-outline-primary me-2" href="/Home/Index">
                <i class="fas fa-arrow-left"></i> Volver
            </a>

            @if (Context.Session.GetString("Rol") == "admin")
            {
                <a class="btn btn-success shadow-sm" href="/Producto/Create">
                    <i class="fas fa-plus"></i> Nuevo Producto
                </a>
            }
        </div>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <!-- Visualización de la Imagen -->
                    <img src="@(string.IsNullOrEmpty(item.ImagenUrl) ? "/images/no-image.png" : item.ImagenUrl)"
                         class="card-img-top"
                         alt="@item.Nombre"
                         style="height: 200px; object-fit: cover;">

                    <div class="card-body">
                        <h5 class="card-title fw-bold text-truncate">@item.Nombre</h5>
                        <p class="card-text text-muted mb-1">
                            <span class="badge bg-info text-dark">@item.Categoria?.Nombre</span>
                        </p>
                        <p class="card-text mb-2">
                            <strong>Precio:</strong> <span class="text-success">$@item.Precio</span><br />
                            <strong>Stock:</strong> @item.Stock unidades
                        </p>
                    </div>

                    @if (Context.Session.GetString("Rol") == "admin")
                    {
                        <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between pb-3">
                            <a class="btn btn-warning btn-sm px-3" href="/Producto/Edit/@item.Id">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                            <a class="btn btn-danger btn-sm px-3" href="/Producto/Delete/@item.Id"
                               onclick="return confirm('¿Está seguro de eliminar este producto?')">
                                <i class="fas fa-trash"></i> Eliminar
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>