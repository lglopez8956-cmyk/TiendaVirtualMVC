@model List<TiendaVirtualMVC.Models.Categoria>

<div class="container mt-4">
    <h2 class="mb-3">Lista de Categorías</h2>

    <div class="mb-3">
        @* BOTÓN VOLVER AZUL *@
        <a class="btn btn-primary" href="/Home/Index">
            Volver
        </a>

        @* Opcional: Si quieres un botón de crear categorías lo pondrías aquí *@
        @* <a class="btn btn-success" href="/Categoria/Create">+ Nueva Categoría</a> *@
    </div>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cat in Model)
            {
                <tr>
                    <td>@cat.Nombre</td>
                    <td>@cat.Descripcion</td>
                    <td>
                        @if (string.IsNullOrEmpty(cat.Nombre))
                        {
                            <span class="badge bg-danger">Sin nombre</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Activa</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>