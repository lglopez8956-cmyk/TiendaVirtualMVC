@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model List<TiendaVirtualMVC.Models.Categoria>

@{
    var rol = HttpContextAccessor.HttpContext.Session.GetString("Rol")?.Trim();
    bool esAdmin = string.Equals(rol, "Admin", StringComparison.OrdinalIgnoreCase);
}

<div class="container mt-4">
    <h2 class="mb-3">Lista de Categorías</h2>

    <div class="mb-3">
        <a class="btn btn-primary" href="/Home/Index">Volver</a>

        @if (esAdmin)
        {
            <a class="btn btn-success" asp-action="Create">+ Nueva Categoría</a>
        }
    </div>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Descripción</th>
                @if (esAdmin)
                {
                    <th>Acciones</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var cat in Model)
            {
                <tr>
                    <td>@cat.Nombre</td>
                    <td>@cat.Descripcion</td>
                    @if (esAdmin)
                    {
                        <td>
                            <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-warning btn-sm">Editar</a>
                            <form asp-action="Delete" asp-route-id="@cat.Id" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Eliminar?')">Eliminar</button>
                            </form>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>