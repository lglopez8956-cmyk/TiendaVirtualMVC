@model List<TiendaVirtualMVC.Models.Usuario>

@{
    ViewData["Title"] = "Usuario";
}

<div class="container mt-4">

    <h2 class="mb-3">Lista de Usuarios</h2>

    <a class="btn btn-success mb-3" href="/Usuario/Create">Nuevo Usuario</a>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Correo</th>
                <th>Rol</th>
                <th>Celular</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nombre</td>
                    <td>@item.Correo</td>
                    <td>@item.Rol</td>
                    <td>@item.celular</td>

                    <td>
                        <a class="btn btn-warning btn-sm" href="/Usuario/Edit/@item.Id">Editar</a>

                        @if (Context.Session.GetString("Rol") == "admin")
                        {
                            <a class="btn btn-danger btn-sm" href="/Usuario/Delete/@item.Id">Eliminar</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>