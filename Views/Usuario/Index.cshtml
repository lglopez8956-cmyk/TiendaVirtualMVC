@using Microsoft.AspNetCore.Http
<div class="container mt-4">

    <h2 class="mb-3">Gestión de Usuarios</h2>

    @* Bloqueamos el acceso al botón de creación para no-admins *@
    @if (Context.Session.GetString("Rol") == "admin")
    {
        <a class="btn btn-success mb-3" href="/Usuario/Create">
            + Nuevo Usuario
        </a>
    }

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Correo</th>
                <th>Rol</th>

                @* TALLER: El encabezado "Acciones" desaparece si no es admin *@
                @if (Context.Session.GetString("Rol") == "admin")
                {
                    <th>Acciones</th>
                }
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nombre</td>
                    <td>@item.Correo</td>
                    <td>@item.Rol</td>

                    @* TALLER: La celda (td) completa solo se crea para el admin *@
                    @if (Context.Session.GetString("Rol") == "admin")
                    {
                        <td>
                            <a class="btn btn-warning btn-sm" href="/Usuario/Edit/@item.Id">Editar</a>
                            <a class="btn btn-danger btn-sm" href="/Usuario/Delete/@item.Id">Eliminar</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>

</div>