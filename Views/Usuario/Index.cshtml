

<h2 class="mb-4">👤 Usuarios</h2>

<a class="btn btn-primary mb-3" asp-action="Create">➕ Crear Usuario</a>

<div class="card shadow p-3">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Celular</th>
                <th>Rol</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nombre</td>
                    <td>@item.Celular</td>
                    <td>@item.Rol</td>
                    <td class="text-center">
                        <a class="btn btn-success btn-sm" asp-action="Edit" asp-route-id="@item.Id">✏️ Editar</a>
                        <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">🗑️ Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
